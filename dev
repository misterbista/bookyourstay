#!/bin/sh

set -eu

ROOT_DIR=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)

compose() {
  (
    cd "$ROOT_DIR"
    docker compose -f compose.yml "$@"
  )
}

ensure_docker() {
  if ! command -v docker >/dev/null 2>&1; then
    echo "Docker is required but was not found on PATH." >&2
    exit 1
  fi

  if ! docker compose version >/dev/null 2>&1; then
    echo "docker compose is required but is not available." >&2
    exit 1
  fi
}

ensure_running() {
  if ! compose ps --status running --services | grep -qx "dev-env"; then
    echo "The dev environment is not running. Start it with 'sh ./dev up' first." >&2
    exit 1
  fi
}

usage() {
  cat <<'EOF'
Usage: sh ./dev <command>

Commands:
  up         Start postgres, minio, and the dev container
  down       Stop the full local environment
  build      Rebuild the dev container image
  shell      Open a shell inside the dev container
  install    Install Bun dependencies and restore .NET packages
  backend    Run the backend in a dedicated dev container
  frontend   Run the frontend in a dedicated dev container
  all        Start the full local environment with backend and frontend
  check      Run the main verification suite inside the dev container
  logs       Tail service logs
  ps         Show container status
  help       Show this help
EOF
}

ensure_docker

command_name="${1:-help}"

case "$command_name" in
  up)
    shift
    compose up -d postgres minio minio-init dev-env "$@"
    ;;
  down)
    shift
    compose down "$@"
    ;;
  build)
    shift
    compose build dev-env "$@"
    ;;
  shell)
    shift
    ensure_running
    compose exec dev-env bash "$@"
    ;;
  install)
    shift
    ensure_running
    compose exec dev-env sh -lc "bun install && dotnet restore bookyourstay.sln"
    ;;
  backend)
    shift
    compose up backend-dev "$@"
    ;;
  frontend)
    shift
    compose up frontend-dev "$@"
    ;;
  all)
    shift
    compose up -d postgres minio minio-init dev-env backend-dev frontend-dev "$@"
    ;;
  check)
    shift
    ensure_running
    compose exec dev-env sh -lc "bun run check"
    ;;
  logs)
    shift
    compose logs -f postgres minio dev-env backend-dev frontend-dev "$@"
    ;;
  ps)
    shift
    compose ps "$@"
    ;;
  help|-h|--help)
    usage
    ;;
  *)
    echo "Unknown command: $command_name" >&2
    echo >&2
    usage >&2
    exit 1
    ;;
esac
