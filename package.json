{
  "name": "bookyourstay",
  "private": true,
  "packageManager": "bun@1.3.4",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run dev:backend",
    "dev:backend": "dotnet watch --project apps/backend",
    "dev:frontend": "bun run --filter frontend dev",
    "dev:all": "sh ./scripts/dev-all.sh",
    "build": "bun run build:backend && bun run build:frontend",
    "build:backend": "dotnet build apps/backend/backend.csproj",
    "build:frontend": "bun run --filter frontend build",
    "test": "bun run test:backend",
    "test:backend": "dotnet test apps/backend/tests/backend.UnitTests/backend.UnitTests.csproj && dotnet test apps/backend/tests/backend.IntegrationTests/backend.IntegrationTests.csproj",
    "lint": "bun run lint:frontend",
    "lint:frontend": "bun run --filter frontend lint",
    "typecheck": "bun run typecheck:frontend",
    "typecheck:frontend": "bun run --filter frontend typecheck",
    "format": "bun run format:frontend",
    "format:frontend": "bun run --filter frontend format",
    "start:backend": "dotnet run --project apps/backend",
    "start:frontend": "bun run --filter frontend start",
    "infra:up": "docker compose -f compose.yml up -d",
    "infra:down": "docker compose -f compose.yml down",
    "infra:logs": "docker compose -f compose.yml logs -f postgres minio",
    "check": "bun run build && bun run test:backend && bun run lint:frontend && bun run typecheck:frontend"
  }
}
